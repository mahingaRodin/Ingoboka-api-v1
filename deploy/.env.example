# Copy to deploy/.env (never commit the real .env)
# Location on server: /opt/ingoboka/deploy/.env

# ===== PostgreSQL (Docker Compose service name: postgres) =====
POSTGRES_DB=ingoboka
POSTGRES_USER=ingoboka
# Quote passwords that contain special characters (e.g. !)
POSTGRES_PASSWORD="change-me-strong-password"

# ===== API =====
JWT_SECRET=change-me-use-openssl-rand-base64-32
API_PORT=8085
SEED_PLATFORM_ADMIN=true
IMAGE_TAG=latest

# ===== Platform admin (seeded once on first deploy if email is new) =====
# Changing these later does NOT update an existing admin — reset password in DB or via forgot-password.
PLATFORM_ADMIN_EMAIL=agressive.one04@gmail.com
PLATFORM_ADMIN_PASSWORD=change-me-strong-admin-password
PLATFORM_ADMIN_PHONE=+250794415318

# ===== Frontend (production) =====
CORS_ALLOWED_ORIGINS=https://app.ingoboka.rw
FRONTEND_VERIFY_EMAIL_URL=https://app.ingoboka.rw/verify-email

# ===== Demo data seed (docker profile) =====
SEED_DEMO_DATA=true

# ===== Gmail / SMTP (required for OTP and account emails) =====
# MUST be a Gmail App Password (16 chars) — NOT your normal Gmail password.
# Create at: https://myaccount.google.com/apppasswords (requires 2-Step Verification).
# Paste with or without spaces — the API strips spaces automatically.
# If you see "535-5.7.8 BadCredentials", regenerate the app password and update below.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
# Set true only after SMTP works (optional deep health check)
MAIL_HEALTH_ENABLED=false

# ===== Redis (OTP) — hostname is the Docker service name =====
# REDIS_HOST and REDIS_PORT are injected by docker-compose

# ===== OTP delivery (no paid SMS required for demo) =====
# email = send 6-digit code by email (default, recommended)
# sms   = MTN bulk SMS (paid — set MTN_BULK_SMS_ENABLED=true and API key)
# log   = dev only — OTP appears in `docker compose logs api`
OTP_DELIVERY_CHANNEL=email
MTN_BULK_SMS_ENABLED=false

# ===== MinIO (document storage) — optional overrides =====
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=ingoboka-documents
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# NOTE: Do NOT use localhost in DB_URL when running in Docker.
# The API container connects to hostname "postgres", not your machine.
# DB_URL is set automatically by docker-compose — you do not need it here.
